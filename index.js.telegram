/* =====================================================
   DEPENDENCIES
===================================================== */

const TelegramBot = require("node-telegram-bot-api");
const OpenAI = require("openai");
const cron = require("node-cron");

const db = require("./models/db");

// Core
const simulateCashflow = require("./core/simulation");

// Services
const createLedgerService = require("./services/ledgerService");
const createFinanceEngine = require("./services/financeEngine");
const createRecurringProcessor = require("./services/recurringProcessor");

const reportService = require("./services/reportService");
const recurringService = require("./services/recurringService");

// Auto-load handlers
const registerAllHandlers = require("./handlers");

/* =====================================================
   ENVIRONMENT CHECKS
===================================================== */

if (!process.env.TELEGRAM_BOT_TOKEN) {
  console.error("TELEGRAM_BOT_TOKEN not set");
  process.exit(1);
}

if (!process.env.OPENAI_API_KEY) {
  console.error("OPENAI_API_KEY not set");
  process.exit(1);
}

/* =====================================================
   INITIALIZATION
===================================================== */

const ledgerService = createLedgerService(db);
const financeEngine = createFinanceEngine(ledgerService);
const recurringProcessor = createRecurringProcessor(db, ledgerService);

const bot = new TelegramBot(process.env.TELEGRAM_BOT_TOKEN, { polling: true });

const openai = new OpenAI({
  apiKey: process.env.OPENAI_API_KEY,
  baseURL: "https://openrouter.ai/api/v1"
});

/* =====================================================
   REGISTER HANDLERS (AUTO-LOAD)
===================================================== */

registerAllHandlers(bot, {
  db,
  ledgerService,
  financeEngine,
  reportService,
  recurringService,
  recurringProcessor,
  simulateCashflow,
  openai
});

/* =====================================================
   CRON JOBS
===================================================== */

// Runs every day at 09:05 local time
cron.schedule("5 9 * * *", () => {
  try {
    const count = recurringProcessor.processDueRecurring();
    console.log(`[cron] recurring processor posted ${count} transaction(s)`);
  } catch (err) {
    console.error("[cron] recurring processor failed:", err);
  }
});

console.log("Bot started.");

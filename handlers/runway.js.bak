// handlers/runway.js

module.exports = function registerRunwayHandler(bot, deps) {

  bot.onText(/\/runway/, async (msg) => {

    try {

      const result = deps.financeEngine.calculateRunway();

      if (result.profitable) {
        return bot.sendMessage(
          msg.chat.id,
          `🚀 You are profitable.\n\n` +
          `Income (30d): ${result.operatingIncome}\n` +
          `Expenses (30d): ${result.operatingExpenses}\n` +
          `Liquid Assets: ${result.liquidAssets}\n\n` +
          `Runway: ∞`
        );
      }

      let warningText = "";

      if (result.warning === "CRITICAL") {
        warningText = "\n⚠️ CRITICAL: Less than 3 months runway!";
      } else if (result.warning === "WARNING") {
        warningText = "\n⚠️ Warning: Less than 6 months runway.";
      }

      return bot.sendMessage(
        msg.chat.id,
        `🔥 Operating Burn: ${result.burnPerMonth.toFixed(2)}/month\n` +
        `💧 Daily Burn: ${result.burnPerDay.toFixed(2)}/day\n` +
        `🏦 Liquid Assets: ${result.liquidAssets.toFixed(2)}\n\n` +
        `⏳ Runway: ${result.runwayMonths.toFixed(1)} months (${result.runwayDays.toFixed(0)} days)` +
        warningText
      );

    } catch (err) {
      console.error(err);
      bot.sendMessage(msg.chat.id, "Error calculating runway.");
    }

  });

};

function getBalances() {
  return db.prepare(`
    SELECT 
      a.name AS account,
      a.type AS type,
      ROUND(SUM(p.amount), 2) AS balance
    FROM postings p
    JOIN accounts a ON p.account_id = a.id
    GROUP BY a.id
    ORDER BY a.type, a.name
  `).all();
}

module.exports = {
  getBalances,
  getBalancesByType,
  getNetWorth,
  getIncomeStatement,
  getExpenseBreakdown,
  getMonthlyCashflow,
  getRegister
};
